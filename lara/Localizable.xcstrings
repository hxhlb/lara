    "Calls a symbol (via dlsym) or an absolute address. Numeric args are passed as x0-x7 then stack.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "调用符号（通过 dlsym）或绝对地址。数字参数会按 x0-x7 然后栈传递。"
          }
        },
        "zh-Hant-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "呼叫符號（透過 dlsym）或絕對位址。數字參數會依 x0-x7 接著堆疊傳遞。"
          }
        }
      }
    },
    "Camera button (18.0rc+)": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
