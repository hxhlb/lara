    "1. Download the IPSW tool for your device.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "1. 下载适用于你设备的 IPSW 工具。"
          }
        },
        "zh-Hant-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "1. 下載適用於你裝置的 IPSW 工具。"
          }
        }
      }
    },
    "1. Switch to hybrid mode in settings\n2. Escape the Sandbox\n3. Initialise VFS\n4. Try again.": {
      "comment": "A message displayed when the file manager is not ready.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "1. 在设置中切换到混合模式\n2. 逃逸沙盒\n3. 初始化 VFS\n4. 重试。"
          }
        },
        "zh-Hant-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "1. 在設定中切換到混合模式\n2. 逃逸沙盒\n3. 初始化 VFS\n4. 再試一次。"
          }
        }
      }
    },
    "2. Extract the archive.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "2. 解压归档。"
          }
        },
        "zh-Hant-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "2. 解壓縮封存檔。"
          }
        }
      }
    },
    "3 App Bypass": {
      "comment": "A system tweak that bypasses 3 apps.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "3 App 限制绕过"
          }
        },
        "zh-Hant-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "3 App 限制繞過"
          }
        }
      }
    },
    "3. Open Terminal.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "3. 打开终端。"
          }
        },
        "zh-Hant-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "3. 打開終端機。"
          }
        }
      }
    },
    "4. Navigate to the extracted folder:": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "4. 进入解压后的文件夹："
          }
        },
        "zh-Hant-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "4. 前往解壓縮後的資料夾："
          }
        }
      }
    },
    "5. Extract the kernel:": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "5. 提取 kernel："
          }
        },
        "zh-Hant-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "5. 解出 kernel："
          }
        }
      }
    },
    "6. Get the kernelcache file.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "6. 获取 kernelcache 文件。"
          }
        },
        "zh-Hant-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "6. 取得 kernelcache 檔案。"
          }
        }
      }
    },
    "7. Transfer the kernelcache to your iCloud or iPhone.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "7. 将 kernelcache 传到 iCloud 或 iPhone。"
          }
        },
        "zh-Hant-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "7. 將 kernelcache 傳到 iCloud 或 iPhone。"
          }
        }
      }
    },
    "8. Tap the button above and select the kernelcache, for example kernelcache.release.iPhone14,3.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "8. 点击上方按钮并选择 kernelcache，例如 kernelcache.release.iPhone14,3。"
          }
        },
        "zh-Hant-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "8. 點上方按鈕並選取 kernelcache，例如 kernelcache.release.iPhone14,3。"
          }
        }
      }
    },
